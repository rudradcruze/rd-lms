generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum EnrollmentStatus {
  PENDING
  APPROVED
  REJECTED
  WITHDRAWN
}

model User {
  id                BigInt             @id @default(autoincrement())
  username          String             @unique @db.VarChar(16)
  email             String             @unique
  passwordHash      String             @map("password_hash")
  isActive          Boolean            @default(true) @map("is_active")
  isBlocked         Boolean            @default(false) @map("is_blocked")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  refreshTokens     RefreshToken[]
  userRoles         UserRole[]
  userPermissions   UserPermission[]
  userInfo          UserInfo?
  createdCourses       Course[]       @relation("CourseCreator")
  courseInstructors    CourseInstructor[]
  enrollmentsAsStudent Enrollment[]   @relation("EnrollmentStudent")
  enrollmentsApproved  Enrollment[]   @relation("EnrollmentApprovedBy")
  enrollmentsRejected  Enrollment[]   @relation("EnrollmentRejectedBy")
  enrollmentsWithdrawn Enrollment[]   @relation("EnrollmentWithdrawnBy")
  createdContents      CourseContent[]

  @@map("users")
}

model RefreshToken {
  id            BigInt    @id @default(autoincrement())
  userId        BigInt    @map("user_id")
  tokenHash     String    @unique @map("token_hash")
  expiresAt     DateTime  @map("expires_at")
  blacklistedAt DateTime? @map("blacklisted_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Role {
  id              BigInt           @id @default(autoincrement())
  name            String           @unique
  key             String           @unique
  description     String?
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id              BigInt           @id @default(autoincrement())
  name            String           @unique
  key             String           @unique
  resource        String
  action          String
  description     String?
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  rolePermissions RolePermission[]
  userPermissions UserPermission[]

  @@map("permissions")
}

model UserRole {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  roleId    BigInt   @map("role_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId], map: "unique_user_role")
  @@map("user_roles")
}

model RolePermission {
  id           BigInt   @id @default(autoincrement())
  roleId       BigInt   @map("role_id")
  permissionId BigInt   @map("permission_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId], map: "unique_role_permission")
  @@map("role_permissions")
}

model UserPermission {
  id           BigInt   @id @default(autoincrement())
  userId       BigInt   @map("user_id")
  permissionId BigInt   @map("permission_id")
  allowed      Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId], map: "unique_user_permission")
  @@map("user_permissions")
}

model UserInfo {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @unique @map("user_id")
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_info")
}

model CourseCategory {
  id          BigInt   @id @default(autoincrement())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  courses     Course[]

  @@map("course_categories")
}

model Course {
  id               BigInt             @id @default(autoincrement())
  title            String
  slug             String             @unique
  shortDescription String?            @map("short_description")
  description      String?
  thumbnailUrl     String?            @map("thumbnail_url")
  status           CourseStatus       @default(DRAFT)
  categoryId       BigInt?            @map("category_id")
  createdById      BigInt             @map("created_by_id")
  deletedAt        DateTime?          @map("deleted_at")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  category         CourseCategory?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  creator          User               @relation("CourseCreator", fields: [createdById], references: [id], onDelete: Restrict)
  instructors      CourseInstructor[]
  settings         CourseSettings?
  enrollments      Enrollment[]
  sections         CourseSection[]

  @@index([status])
  @@index([categoryId])
  @@map("courses")
}

model CourseInstructor {
  id        BigInt   @id @default(autoincrement())
  courseId  BigInt   @map("course_id")
  userId    BigInt   @map("user_id")
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId], map: "unique_course_instructor")
  @@map("course_instructors")
}

model CourseSettings {
  id                  BigInt   @id @default(autoincrement())
  courseId            BigInt   @unique @map("course_id")
  allowSelfEnrollment Boolean  @default(true) @map("allow_self_enrollment")
  requiresApproval    Boolean  @default(false) @map("requires_approval")
  showInCatalog       Boolean  @default(true) @map("show_in_catalog")
  enableDiscussions   Boolean  @default(true) @map("enable_discussions")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  course              Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@map("course_settings")
}

model Enrollment {
  id            BigInt           @id @default(autoincrement())
  studentId     BigInt           @map("student_id")
  courseId      BigInt           @map("course_id")
  status        EnrollmentStatus
  approvedAt    DateTime?        @map("approved_at")
  approvedById  BigInt?          @map("approved_by_id")
  rejectedAt    DateTime?        @map("rejected_at")
  rejectedById  BigInt?          @map("rejected_by_id")
  withdrawnAt   DateTime?        @map("withdrawn_at")
  withdrawnById BigInt?          @map("withdrawn_by_id")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  student     User   @relation("EnrollmentStudent", fields: [studentId], references: [id], onDelete: Restrict)
  course      Course @relation(fields: [courseId], references: [id], onDelete: Restrict)
  approvedBy  User?  @relation("EnrollmentApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  rejectedBy  User?  @relation("EnrollmentRejectedBy", fields: [rejectedById], references: [id], onDelete: SetNull)
  withdrawnBy User?  @relation("EnrollmentWithdrawnBy", fields: [withdrawnById], references: [id], onDelete: SetNull)

  @@unique([studentId, courseId], map: "unique_student_course")
  @@index([studentId])
  @@index([courseId])
  @@index([status])
  @@map("enrollments")
}

enum ContentType {
  VIDEO
  PDF
  NOTE
  IMAGE
  AUDIO
  EXTERNAL_LINK
}

model CourseSection {
  id          BigInt          @id @default(autoincrement())
  courseId    BigInt          @map("course_id")
  title       String
  description String?
  position    Int
  isPublished Boolean         @default(false) @map("is_published")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  course      Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  contents    CourseContent[]

  @@index([courseId])
  @@map("course_sections")
}

model CourseContent {
  id          BigInt         @id @default(autoincrement())
  sectionId   BigInt         @map("section_id")
  title       String
  description String?
  contentType ContentType    @map("content_type")
  position    Int
  isPublished Boolean        @default(false) @map("is_published")
  createdById BigInt         @map("created_by_id")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  section     CourseSection  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  assets      ContentAsset[]
  creator     User           @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([sectionId])
  @@map("course_contents")
}

model ContentAsset {
  id               BigInt        @id @default(autoincrement())
  contentId        BigInt        @map("content_id")
  provider         String
  publicId         String?       @map("public_id")
  secureUrl        String        @map("secure_url")
  originalFileName String?       @map("original_file_name")
  mimeType         String?       @map("mime_type")
  sizeBytes        BigInt?       @map("size_bytes")
  durationSeconds  Int?          @map("duration_seconds")
  createdAt        DateTime      @default(now()) @map("created_at")
  content          CourseContent @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentId])
  @@map("content_assets")
}
